# Required
ANTHROPIC_API_KEY=your-api-key-here

# Browser profile path (mounted into Docker container)
BROWSER_PROFILE_PATH=./browser-profile

# Platform to manage (default: x)
PLATFORM=x

# Model to use for Computer Use agent loop
MODEL=claude-opus-4-6

# Scheduling
POSTS_PER_DAY=3
ENGAGEMENT_CYCLE_INTERVAL_HOURS=2
COMMENTS_PER_CYCLE=5
ANALYTICS_SCRAPE_INTERVAL_HOURS=6

# Adaptive learning
WEIGHT_EVAL_PERIOD_DAYS=14
LEARNING_RATE=0.1
MIN_WEIGHT_FLOOR=0.05

# Rate limits
MAX_POSTS_PER_DAY=10
MAX_COMMENTS_PER_HOUR=10

# Safety
REQUIRE_APPROVAL=false
DRY_RUN=false

# Docker / display
DISPLAY_WIDTH=1024
DISPLAY_HEIGHT=768
ENABLE_VNC=false

# Database
DB_PATH=data/moderator.db
